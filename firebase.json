{
  "hosting": {
    "public": "output/preview",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "X-Robots-Tag", "value": "noindex, nofollow" },
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      }
    ]
  }
}
